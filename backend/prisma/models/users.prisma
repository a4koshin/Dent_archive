model User {
  id       String     @id @default(uuid())
  fullName String
  email    String     @unique
  password String
  role     UserRole   @default(DENTIST)
  status   UserStatus @default(ACTIVE)

  cases  TreatmentCase[] @relation("DoctorCases")
  images PatientImage[]  @relation("UploadedImages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DENTIST
  ASSISTANT
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}
