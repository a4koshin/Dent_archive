model TreatmentCase {
  id        String @id @default(uuid())
  patientId String
  doctorId  String

  title         String
  description   String?
  treatmentType TreatmentType
  status        CaseStatus    @default(ONGOING)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  patient Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User           @relation("DoctorCases", fields: [doctorId], references: [id], onDelete: Restrict)
  images  PatientImage[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  publicGalleries PublicGallery[]
}

enum TreatmentType {
  TEETH_WHITENING
  BRACES
  IMPLANT
  CLEANING
  ROOT_CANAL
  CROWN
  VENEERS
  EXTRACTION
  OTHER
}

enum CaseStatus {
  ONGOING
  COMPLETED
  CANCELLED
}
